model Page {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  sections        Section[]
}

model Section {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String
  order     Int
  enabled   Boolean  @default(true)
  content   Json     @default("{}")
  updatedAt DateTime @updatedAt
}

